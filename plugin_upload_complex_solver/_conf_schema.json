{
  "solver_provider": {
    "type": "string",
    "default": "",
    "description": "解题模型1提供商ID",
    "hint": "第一个解题模型提供商",
    "_special": "select_provider"
  },
  "solver_model": {
    "type": "string",
    "default": "",
    "description": "解题模型1名称（可选）",
    "hint": "第一个解题模型的具体模型ID"
  },
  "solver_provider_2": {
    "type": "string",
    "default": "",
    "description": "解题模型2提供商ID",
    "hint": "第二个解题模型提供商（双模型并行）",
    "_special": "select_provider"
  },
  "solver_model_2": {
    "type": "string",
    "default": "",
    "description": "解题模型2名称（可选）",
    "hint": "第二个解题模型的具体模型ID"
  },
  "summarize_provider": {
    "type": "string",
    "default": "",
    "description": "精简模型提供商ID",
    "hint": "用于精简解题输出的模型（留空则使用解题模型1）",
    "_special": "select_provider"
  },
  "summarize_model": {
    "type": "string",
    "default": "",
    "description": "精简模型名称（可选）",
    "hint": "精简模型的具体模型ID"
  },
  "enable_latex_render": {
    "type": "bool",
    "default": true,
    "description": "启用 LaTeX 公式渲染",
    "hint": "开启后会将数学公式渲染为图片显示"
  },
  "enable_context": {
    "type": "bool",
    "default": true,
    "description": "启用上下文记忆",
    "hint": "是否记住之前的复杂问题对话上下文"
  },
  "context_timeout": {
    "type": "int",
    "default": 600,
    "description": "上下文超时时间（秒）",
    "hint": "追问的有效时间范围"
  },
  "enable_summarize": {
    "type": "bool",
    "default": true,
    "description": "精简解题输出",
    "hint": "开启后会调用精简模型对原始输出进行精简"
  },
  "max_wait_minutes": {
    "type": "int",
    "default": 9,
    "description": "最大等待时间（分钟）",
    "hint": "解题模型最大总等待时间，默认9分钟"
  }
}